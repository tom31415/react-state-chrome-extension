{
  "name": "react-state-inspector",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome DevTools extension: inspect React (15+) components and view/edit Redux and React Query state live.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "test": "node --test",
    "test:e2e": "npm run build --silent && node --test --test-concurrency=3 e2e/*.e2e.mjs",
    "test:all": "npm test && npm run test:e2e"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "playwright-core": "^1.61.1"
  }
}
