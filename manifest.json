{
  "manifest_version": 3,
  "name": "React + Redux Inspector",
  "version": "0.1.0",
  "description": "Inspect React (v15+) components visually and view/edit Redux store state live from a DevTools panel.",
  "minimum_chrome_version": "111",
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["page-agent.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
