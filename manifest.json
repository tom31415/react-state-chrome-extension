{
  "manifest_version": 3,
  "name": "React + State Inspector",
  "version": "0.0.1",
  "description": "Inspect React (v15+) components visually and view/edit Redux and React Query state live from a DevTools panel.",
  "minimum_chrome_version": "111",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["page-agent.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
